# Copy to .env and adjust. Do not commit real secrets.

# --- Server ---
# LOG_LEVEL=DEBUG
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# ONTOLOGY_DIR=/absolute/path/to/ontology
# HOST=127.0.0.1
# PORT=8000
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- OpenRouter (optional LLM for A2UI / collect schema) ---
# ENABLE_LLM_FORM_SCHEMA=1
# ENABLE_LLM_FULL_A2UI=1
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=a2ui-demo

# --- Tests ---
# DISABLE_ONTOLOGY_WATCHER=1
